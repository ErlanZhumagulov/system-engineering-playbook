<mxfile host="app.diagrams.net" version="26.0.14">
  <diagram name="Page-1">
<mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- Title -->
    <mxCell id="title" value="LMS+P — C4 Component Diagram: Proctoring Service" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="20" width="1000" height="40" as="geometry" />
    </mxCell>

    <!-- Proctoring Service boundary -->
    <mxCell id="ps_boundary" value="Proctoring Service" style="text;html=1;strokeColor=#0066CC;fillColor=#EEF4FF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#0066CC;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="290" y="70" width="980" height="720" as="geometry" />
    </mxCell>

    <!-- Components -->
    <mxCell id="session_mgr" value="&lt;b&gt;Session Manager&lt;/b&gt;&lt;br&gt;[Component: Go]&lt;br&gt;&lt;br&gt;Создание, управление и&lt;br&gt;завершение экзаменационных&lt;br&gt;сессий. Хранит статус в PostgreSQL." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="530" y="130" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="webrtc_sig" value="&lt;b&gt;WebRTC Signaling&lt;/b&gt;&lt;br&gt;[Component: Go + WebSocket]&lt;br&gt;&lt;br&gt;Обмен SDP/ICE с браузером.&lt;br&gt;Инициализирует WebRTC-комнату&lt;br&gt;на медиасервере." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="320" y="310" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="event_detector" value="&lt;b&gt;Event Detector&lt;/b&gt;&lt;br&gt;[Component: Go + ML SDK]&lt;br&gt;&lt;br&gt;Анализирует видеофрейм:&lt;br&gt;face_absent, multiple_faces,&lt;br&gt;tab_switch, foreign_audio." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="740" y="310" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="verdict_handler" value="&lt;b&gt;Verdict Handler&lt;/b&gt;&lt;br&gt;[Component: Go]&lt;br&gt;&lt;br&gt;Принимает вердикты проктора.&lt;br&gt;Рассчитывает итог (approved /&lt;br&gt;rejected / escalated)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="530" y="310" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="s3_uploader" value="&lt;b&gt;S3 Uploader&lt;/b&gt;&lt;br&gt;[Component: Go]&lt;br&gt;&lt;br&gt;Загружает видеозапись в S3&lt;br&gt;после завершения сессии.&lt;br&gt;Генерирует pre-signed URL." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="320" y="520" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="event_publisher" value="&lt;b&gt;Event Publisher&lt;/b&gt;&lt;br&gt;[Component: Go + RabbitMQ]&lt;br&gt;&lt;br&gt;Публикует события в очередь:&lt;br&gt;proctoring.alert.detected,&lt;br&gt;proctoring.verdict.submitted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="740" y="520" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="audit_writer" value="&lt;b&gt;Audit Log Writer&lt;/b&gt;&lt;br&gt;[Component: Go]&lt;br&gt;&lt;br&gt;Фиксирует все обращения&lt;br&gt;к видеозаписям в&lt;br&gt;access_audit_log." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="530" y="520" width="220" height="120" as="geometry" />
    </mxCell>

    <!-- External systems -->
    <mxCell id="api_gw" value="&lt;b&gt;API Gateway&lt;/b&gt;&lt;br&gt;[Container]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="60" y="180" width="160" height="60" as="geometry" />
    </mxCell>

    <mxCell id="webrtc_media" value="&lt;b&gt;WebRTC Медиасервер&lt;/b&gt;&lt;br&gt;[External: Janus/MediaSoup]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="60" y="340" width="180" height="60" as="geometry" />
    </mxCell>

    <mxCell id="s3_ext" value="&lt;b&gt;S3-хранилище&lt;/b&gt;&lt;br&gt;[External]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="60" y="550" width="160" height="60" as="geometry" />
    </mxCell>

    <mxCell id="rabbitmq_ext" value="&lt;b&gt;RabbitMQ&lt;/b&gt;&lt;br&gt;[Container]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="1060" y="550" width="160" height="60" as="geometry" />
    </mxCell>

    <mxCell id="postgres_ext" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;[Container: DB]" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1060" y="130" width="160" height="80" as="geometry" />
    </mxCell>

    <mxCell id="assess_ext" value="&lt;b&gt;Assessment Service&lt;/b&gt;&lt;br&gt;[Container]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="1060" y="340" width="160" height="60" as="geometry" />
    </mxCell>

    <!-- Internal edges -->
    <mxCell id="ie1" value="создаёт сессию" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="session_mgr" target="webrtc_sig" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ie2" value="запускает детекцию" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="session_mgr" target="event_detector" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ie3" value="завершение → upload" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="session_mgr" target="s3_uploader" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ie4" value="тревога → публикация" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="event_detector" target="event_publisher" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ie5" value="вердикт → публикация" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="verdict_handler" target="event_publisher" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ie6" value="запись доступа" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s3_uploader" target="audit_writer" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- External edges -->
    <mxCell id="ee1" value="REST / WebSocket" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="api_gw" target="session_mgr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ee2" value="сигналинг" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="webrtc_sig" target="webrtc_media" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ee3" value="upload MP4" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s3_uploader" target="s3_ext" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ee4" value="publish events" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="event_publisher" target="rabbitmq_ext" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ee5" value="read/write сессии" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="session_mgr" target="postgres_ext" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ee6" value="audit log" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="audit_writer" target="postgres_ext" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
